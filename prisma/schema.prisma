// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// --- USER MANAGEMENT ---

enum UserTier {
  SMART_USER
  RESELLER
  API_PARTNER
  ADMIN
}

model User {
  id            String   @id @default(uuid())
  fullName      String?
  email         String   @unique
  phoneNumber   String   @unique
  passwordHash  String
  tier          UserTier @default(SMART_USER)
  isKycVerified Boolean  @default(false)

  // Security Fields
  failedLoginAttempts Int       @default(0)
  lockoutUntil        DateTime?
  transactionPin      String? // We make it optional initially to not break existing users without it

  // Relationships
  wallet         Wallet? // Moved balance here
  kycData        KycData?
  transactions   Transaction[]
  flightRequests FlightBookingRequest[]
  activitiesDone FlightRequestActivity[]
  refreshTokens  RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email, phoneNumber])
}

enum StaffRole {
  TICKETING_OFFICER
  SUPER_ADMIN
}

model Staff {
  id                     String    @id @default(uuid())
  email                  String    @unique
  passwordHash           String
  fullName               String
  role                   StaffRole @default(TICKETING_OFFICER)
  isActive               Boolean   @default(true)
  requiresPasswordChange Boolean   @default(true)

  activitiesDone FlightRequestActivity[]

  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([userId])
}

// --- WALLET MANAGEMENT ---

model Wallet {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance      Decimal @default(0.00) @db.Decimal(15, 2)
  bonusBalance Decimal @default(0.00) @db.Decimal(15, 2) // For commissions
  totalSpent   Decimal @default(0.00) @db.Decimal(15, 2)

  flightTransactions FlightTransaction[]

  updatedAt DateTime @updatedAt
}

// --- KYC & VIRTUAL ACCOUNTS ---

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

model KycData {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  encryptedBvn String? // Renamed for clarity

  virtualAccountNumber String? @unique
  bankName             String?
  accountReference     String? @unique

  status     KycStatus @default(PENDING)
  verifiedAt DateTime?

  updatedAt DateTime @updatedAt

  @@index([status])
}

// --- UNIFIED TRANSACTIONS ---

enum TransactionType {
  DATA
  AIRTIME
  RECHARGE_PIN
  CABLE_TV
  ELECTRICITY
  WALLET_FUNDING
  EDUCATION
  FLIGHT_BOOKING
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REVERSED
}

model Transaction {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  amount Decimal           @db.Decimal(15, 2)
  fee    Decimal           @default(0.00) @db.Decimal(15, 2)
  type   TransactionType
  status TransactionStatus @default(PENDING)

  reference         String  @unique
  providerReference String? @unique

  idempotencyKey String? @unique
  providerStatus String?

  metadata Json?

  printedPins RechargePin[]

  createdAt DateTime @default(now())

  @@index([userId, status, type, createdAt])
  @@index([status, type])
  @@index([createdAt])
  @@index([userId, createdAt(sort: Desc)])
}

// --- INVENTORY FOR CARD PRINTING ---

enum Network {
  MTN
  GLO
  AIRTEL
  NINE_MOBILE
}

model RechargePin {
  id            String       @id @default(uuid())
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  network      Network
  denomination Int

  pinCode      String
  serialNumber String?
  batchNumber  String?

  isSold Boolean @default(false)

  createdAt DateTime  @default(now())
  soldAt    DateTime?

  @@index([network, denomination, isSold])
}

// --- AUTH OTP ---

model PasswordResetOTP {
  id        String   @id @default(uuid())
  email     String
  otp       String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// --- FLIGHT BOOKING SYSTEM ---

enum FlightRequestStatus {
  FUTURE_HELD
  OPTIONS_PROVIDED
  SELECTION_MADE
  QUOTED
  EXPIRED
  PAID_PROCESSING
  TICKETED
  CANCELLED
  REFUNDED
}

enum TripType {
  ONE_WAY
  ROUND_TRIP
}

model FlightBookingRequest {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Phase 1: Request Data
  origin      String
  destination String
  targetDate  DateTime
  returnDate  DateTime?
  tripType    TripType  @default(ONE_WAY)
  flightClass String    @default("ECONOMY")
  adults      Int       @default(1)
  children    Int       @default(0)
  infants     Int       @default(0)

  // Phase 2: Options & Selection
  flightOptions    Json?
  selectedOptionId String?

  // Phase 3 & 4: Fulfillment Data (Filled by Admin)
  airlineName        String?
  pnr                String?
  ticketingTimeLimit DateTime?
  departureTime      String?
  arrivalTime        String?
  legs               Json?

  // Financials
  netCost      Decimal? @db.Decimal(15, 2)
  sellingPrice Decimal? @db.Decimal(15, 2)

  // Delivery
  eTicketUrl String?

  status           FlightRequestStatus @default(FUTURE_HELD)
  paymentExpiresAt DateTime?

  // Relations
  passengers   Passenger[]
  activityLogs FlightRequestActivity[]

  flightTransaction FlightTransaction? @relation("BookingToTransaction")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([targetDate])
  @@index([status, createdAt])
  @@index([createdAt])
}

model Passenger {
  id              String               @id @default(uuid())
  flightRequestId String
  flightRequest   FlightBookingRequest @relation(fields: [flightRequestId], references: [id], onDelete: Cascade)

  title       String
  firstName   String
  lastName    String
  dateOfBirth DateTime
  gender      String

  createdAt DateTime @default(now())

  @@index([flightRequestId])
}

model FlightRequestActivity {
  id        String               @id @default(uuid())
  requestId String
  request   FlightBookingRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  userId  String?
  user    User?   @relation(fields: [userId], references: [id])
  staffId String?
  staff   Staff?  @relation(fields: [staffId], references: [id])

  previousState String
  newState      String
  actionDetails String? @db.Text

  createdAt DateTime @default(now())

  @@index([requestId])
}

enum FlightTransactionType {
  PAYMENT
  REFUND
}

model FlightTransaction {
  id        String                @id @default(uuid())
  walletId  String
  wallet    Wallet                @relation(fields: [walletId], references: [id])
  type      FlightTransactionType @default(PAYMENT)
  amount    Decimal               @db.Decimal(15, 2)
  reference String                @unique

  flightRequestId String               @unique
  flightRequest   FlightBookingRequest @relation("BookingToTransaction", fields: [flightRequestId], references: [id])

  createdAt DateTime @default(now())

  @@index([walletId])
}

model SavedFlightTemplate {
  id            String    @id @default(uuid())
  airlineName   String
  flightNumber  String?
  origin        String
  destination   String
  flightDate    DateTime?
  departureTime String? // e.g., "10:00 AM"
  arrivalTime   String? // e.g., "02:00 PM"
  flightClass   String
  basePrice     Decimal   @db.Decimal(15, 2)
  notes         String?   @db.Text
  legs          Json? // Array of { airline, flightNumber, origin, destination, departureTime, arrivalTime }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([origin, destination])
}

// --- DATA PLANS SYSTEM ---

model NetworkPlan {
  id         String     @id @default(cuid())
  name       String     @unique // e.g., "MTN"
  externalId String     @unique // The "ID" from your JSON (e.g., "01" for MTN)
  logoUrl    String? // Path to network logo image
  plans      DataPlan[]
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([externalId])
}

// This is the Data Plan model mapped to your provider's JSON
model DataPlan {
  id        String      @id @default(cuid())
  networkId String
  network   NetworkPlan @relation(fields: [networkId], references: [id])

  // --- Mapping to Provider JSON ---
  productId   String @unique // From "PRODUCT_ID" (e.g., "mtn-10mb-100")
  productCode String // From "PRODUCT_CODE"
  rawName     String // The messy name from provider: "110MB Daily Plan (1 Day) - N100"

  // --- Your App's Customization ---
  displayName String // Clean name for users: "110MB Daily"
  planType    String // SME, Gifting, Binge, Corporate, etc.
  validity    String // e.g., "1 Day", "30 Days"

  // --- Pricing Logic ---
  costPrice     Decimal @db.Decimal(15, 2) // The "PRODUCT_AMOUNT" from JSON (What you pay)
  userPrice     Decimal @db.Decimal(15, 2) // Your custom price for normal users

  // --- Controls ---
  isActive    Boolean @default(true)
  isBestValue Boolean @default(false) // To highlight specific plans in UI
  sortOrder   Int     @default(0)     // Manual ordering

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([networkId])
  @@index([productId])
}
