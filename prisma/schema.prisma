// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// --- USER MANAGEMENT ---

enum UserTier {
  SMART_USER
  RESELLER
  API_PARTNER
  ADMIN
}

model User {
  id            String   @id @default(uuid())
  fullName      String?
  email         String   @unique
  phoneNumber   String   @unique
  passwordHash  String
  tier          UserTier @default(SMART_USER)
  isKycVerified Boolean  @default(false)

  // Security Fields
  failedLoginAttempts Int       @default(0)
  lockoutUntil        DateTime?
  transactionPin      String? // We make it optional initially to not break existing users without it

  // Relationships
  wallet         Wallet? // Moved balance here
  kycData        KycData?
  transactions   Transaction[]
  flightRequests FlightBookingRequest[]
  activitiesDone FlightRequestActivity[]
  refreshTokens  RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email, phoneNumber])
}

enum StaffRole {
  TICKETING_OFFICER
  SUPER_ADMIN
}

model Staff {
  id                     String    @id @default(uuid())
  email                  String    @unique
  passwordHash           String
  fullName               String
  role                   StaffRole @default(TICKETING_OFFICER)
  isActive               Boolean   @default(true)
  requiresPasswordChange Boolean   @default(true)

  activitiesDone FlightRequestActivity[]

  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// --- WALLET MANAGEMENT ---

model Wallet {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance      Decimal @default(0.00) @db.Decimal(15, 2)
  bonusBalance Decimal @default(0.00) @db.Decimal(15, 2) // For commissions
  totalSpent   Decimal @default(0.00) @db.Decimal(15, 2)

  flightTransactions FlightTransaction[]

  updatedAt DateTime @updatedAt
}

// --- KYC & VIRTUAL ACCOUNTS ---

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

model KycData {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  encryptedBvn String? // Renamed for clarity

  virtualAccountNumber String? @unique
  bankName             String?
  accountReference     String? @unique

  status     KycStatus @default(PENDING)
  verifiedAt DateTime?

  updatedAt DateTime @updatedAt
}

// --- UNIFIED TRANSACTIONS ---

enum TransactionType {
  DATA
  AIRTIME
  RECHARGE_PIN
  CABLE_TV
  ELECTRICITY
  WALLET_FUNDING
  EDUCATION
  FLIGHT_BOOKING
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REVERSED
}

model Transaction {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  amount Decimal           @db.Decimal(15, 2)
  fee    Decimal           @default(0.00) @db.Decimal(15, 2)
  type   TransactionType
  status TransactionStatus @default(PENDING)

  reference         String  @unique
  providerReference String? @unique

  providerStatus String?

  metadata Json?

  printedPins RechargePin[]

  createdAt DateTime @default(now())

  @@index([userId, status, type, createdAt])
}

// --- INVENTORY FOR CARD PRINTING ---

enum Network {
  MTN
  GLO
  AIRTEL
  NINE_MOBILE
}

model RechargePin {
  id            String       @id @default(uuid())
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  network      Network
  denomination Int

  pinCode      String
  serialNumber String?
  batchNumber  String?

  isSold Boolean @default(false)

  createdAt DateTime  @default(now())
  soldAt    DateTime?

  @@index([network, denomination, isSold])
}

// --- AUTH OTP ---

model PasswordResetOTP {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// --- FLIGHT BOOKING SYSTEM ---

enum FlightRequestStatus {
  FUTURE_HELD
  OPTIONS_PROVIDED
  SELECTION_MADE
  QUOTED
  EXPIRED
  PAID_PROCESSING
  TICKETED
  CANCELLED
  REFUNDED
}

enum TripType {
  ONE_WAY
  ROUND_TRIP
}

model FlightBookingRequest {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Phase 1: Request Data
  origin      String
  destination String
  targetDate  DateTime
  returnDate  DateTime?
  tripType    TripType  @default(ONE_WAY)
  flightClass String    @default("ECONOMY")
  adults      Int       @default(1)
  children    Int       @default(0)
  infants     Int       @default(0)

  // Phase 2: Options & Selection
  flightOptions    Json?
  selectedOptionId String?

  // Phase 3 & 4: Fulfillment Data (Filled by Admin)
  airlineName        String?
  pnr                String?
  ticketingTimeLimit DateTime?

  // Financials
  netCost      Decimal? @db.Decimal(15, 2)
  sellingPrice Decimal? @db.Decimal(15, 2)

  // Delivery
  eTicketUrl String?

  status FlightRequestStatus @default(FUTURE_HELD)

  // Relations
  passengers   Passenger[]
  activityLogs FlightRequestActivity[]

  flightTransaction FlightTransaction? @relation("BookingToTransaction")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([targetDate])
}

model Passenger {
  id              String               @id @default(uuid())
  flightRequestId String
  flightRequest   FlightBookingRequest @relation(fields: [flightRequestId], references: [id], onDelete: Cascade)

  title       String
  firstName   String
  lastName    String
  dateOfBirth DateTime
  gender      String

  createdAt DateTime @default(now())
}

model FlightRequestActivity {
  id        String               @id @default(uuid())
  requestId String
  request   FlightBookingRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  userId  String?
  user    User?   @relation(fields: [userId], references: [id])
  staffId String?
  staff   Staff?  @relation(fields: [staffId], references: [id])

  previousState String
  newState      String
  actionDetails String? @db.Text

  createdAt DateTime @default(now())
}

enum FlightTransactionType {
  PAYMENT
  REFUND
}

model FlightTransaction {
  id        String                @id @default(uuid())
  walletId  String
  wallet    Wallet                @relation(fields: [walletId], references: [id])
  type      FlightTransactionType @default(PAYMENT)
  amount    Decimal               @db.Decimal(15, 2)
  reference String                @unique

  flightRequestId String               @unique
  flightRequest   FlightBookingRequest @relation("BookingToTransaction", fields: [flightRequestId], references: [id])

  createdAt DateTime @default(now())
}
